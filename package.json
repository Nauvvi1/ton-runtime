{
  "name": "ton-runtime",
  "version": "0.1.0",
  "description": "Crash-safe, idempotent execution runtime for AI agents on TON.",
  "keywords": [
    "ton",
    "ai-agent",
    "runtime",
    "idempotency",
    "retry",
    "mcp",
    "telegram"
  ],
  "homepage": "https://github.com/example/ton-runtime",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/ton-runtime.git"
  },
  "license": "MIT",
  "author": "OpenAI generated scaffold",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsx watch examples/basic/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx demo/src/server.ts",
    "check": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "express": "^4.21.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
