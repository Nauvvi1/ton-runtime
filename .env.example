# =========================
# OpenAI (AI intent layer)
# =========================

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini


# =========================
# TON MCP (real blockchain mode)
# =========================

# If not set → MockTonAdapter will be used
TON_MCP_BASE_URL=http://localhost:3040/mcp

# Optional: API key for TON center (if used inside MCP)
TONCENTER_API_KEY=your_toncenter_api_key_here


# =========================
# Runtime / Demo config
# =========================

# Use "real" to force TON MCP, otherwise mock will be used
TON_MODE=mock

# Demo server port
PORT=4000


# =========================
# Safety limits (important for judges)
# =========================

# Max TON amount per AI-triggered transaction
MAX_TON_AMOUNT=1

# Allow only specific addresses (comma-separated)
ALLOWED_ADDRESSES=EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Enable dry-run mode (no real transfers)
DRY_RUN=true